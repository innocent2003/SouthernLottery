<resources>

    <style name="HeaderCell">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">8dp</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">#FF3D00</item>
        <item name="android:background">@drawable/cell_border</item>
    </style>

    <style name="PrizeCell">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">8dp</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textStyle">bold</item>
        <item name="android:background">@drawable/prize_bg</item>
    </style>

    <style name="ResultCell">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">8dp</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">#2F3A1E</item>
        <item name="android:background">@drawable/cell_border</item>
    </style>

    <style name="ResultMultiCell">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">8dp</item>
        <item name="android:lineSpacingExtra">4dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">#2F3A1E</item>
        <item name="android:background">@drawable/cell_border</item>
    </style>

</resources>